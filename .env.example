# TerOS - Environment Variables
#
# Copy this to .env and fill in the values for your environment.
# Only infrastructure config goes here. All secrets (API keys, DB credentials)
# are managed in .secrets/ — see .secrets/README.md.

# === Server ===
PORT=3000                          # Backend server port
APP_URL=http://localhost:10002      # Frontend app URL — used for OAuth redirects (required)

# === MCA Configuration ===
MCA_BASE_PATH=/app/mcas            # Path to MCAs directory

# === Static Files URL ===
# Defaults to http://localhost:3000/static if not set
# STATIC_BASE_URL=https://your-domain/static

# === Frontend Configuration (used at build time) ===
# These are baked into the frontend bundle — rebuild required after changes.
# Example: ws://localhost:10001/ws (local) or wss://your-domain/ws (production)
EXPO_PUBLIC_WS_URL=ws://localhost:10001/ws
# Example: http://localhost:10001 (local) or https://your-domain (production)
EXPO_PUBLIC_BACKEND_URL=http://localhost:10001
# Backend URL used by MCAs for OAuth callbacks (Google, etc.)
# Example: http://localhost:3000 (local) or https://your-backend-domain.com (production)
TEROS_BACKEND_URL=http://localhost:3000

# === Docker Environments MCA (optional) ===
# Base domain for ephemeral docker environments (e.g. abc123.envs.yourdomain.com)
# Requires a wildcard DNS record *.envs.yourdomain.com → your server IP
# and a valid SSL cert for that wildcard domain
# DOCKER_ENV_DOMAIN=envs.yourdomain.com
# Host path where workspace volumes are stored on the machine running Docker
# This is needed so the Docker daemon can resolve workspace bind mounts correctly
# WORKSPACE_HOST_PATH=/data/volumes/users

# === Sentry (optional) ===
# Set up your own Sentry project at https://sentry.io
# If not set, error tracking is disabled
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
