# TerOS Backend - Environment Variables
#
# Only infrastructure config goes here.
# All secrets (API keys, DB credentials) are managed in .secrets/
# See .secrets/README.md for details.

# Server Configuration
PORT=3001

# MCA Configuration (Required for tool execution)
# Absolute path to the mcas directory
MCA_BASE_PATH=/absolute/path/to/teros/mcas

# Uploads Configuration (Optional - defaults to ./uploads)
UPLOADS_PATH=./uploads

# Static Files URL (Optional - defaults to http://localhost:3000/static)
# STATIC_BASE_URL=https://your-domain/static

# Base domain for docker-env ephemeral environments
DOCKER_ENV_DOMAIN=envs.teros.ai
