# Test Environment Configuration
# Copy this file to .env.test and adjust values as needed:
#   cp .env.test.example .env.test

# Server port for tests (use a different port to avoid conflicts)
PORT=3099

# MongoDB — spin up a test instance with:
#   docker run -d -p 27018:27017 --name teros-test-mongo mongo:7
MONGODB_URI=mongodb://localhost:27018
MONGODB_DATABASE=teros_test

# Authentication — any random string works for tests
SESSION_TOKEN_SECRET=your-secret-here
