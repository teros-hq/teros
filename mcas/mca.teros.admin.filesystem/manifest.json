{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.teros.admin.filesystem",
  "name": "Filesystem (Admin)",
  "version": "0.9.0",
  "description": "File system operations on host machine. Admin only. Read, write, edit, list, search files and content.",
  "type": "utility",
  "icon": "icon.png",
  "category": "development",
  "entrypoint": "src/index.ts",
  "runtime": {
    "transport": "stdio"
  },
  "author": {
    "name": "Alice Evergreen",
    "email": "alice@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": false,
    "system": false,
    "hidden": false,
    "role": "admin"
  },
  "keywords": ["files", "filesystem", "read", "write", "edit", "search", "host"],
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": false,
    "agent": false
  }
}
