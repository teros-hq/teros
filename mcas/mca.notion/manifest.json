{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.notion",
  "name": "Notion",
  "version": "1.0.0",
  "description": "Notion workspace - pages, databases, blocks, search, comments",
  "type": "integration",
  "icon": "icon.png",
  "category": "productivity",
  "entrypoint": "./src/index.ts",
  "author": {
    "name": "Teros Team",
    "email": "team@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": false,
    "system": false,
    "hidden": false,
    "role": "user"
  },

  "runtime": {
    "transport": "http",
    "containerMode": "per-app",
    "port": 3000,
    "healthCheck": "/health"
  },
  "keywords": ["notion", "notes", "wiki", "documentation", "knowledge-base", "databases"],
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": {
      "type": "oauth2",
      "provider": "notion",
      "systemSecrets": ["CLIENT_ID", "CLIENT_SECRET"],
      "userSecrets": ["ACCESS_TOKEN", "REFRESH_TOKEN"],
      "authorizeUrl": "https://api.notion.com/v1/oauth/authorize",
      "tokenUrl": "https://api.notion.com/v1/oauth/token",
      "scopes": ["read_content", "update_content"],
      "pkce": false
    },
    "agent": false
  }
}
