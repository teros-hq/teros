{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.todoist",
  "name": "Todoist",
  "version": "0.9.0",
  "description": "Todoist task management - tasks, projects, labels, comments",
  "type": "integration",
  "icon": "icon.png",
  "category": "productivity",
  "entrypoint": "mcp/src/index.ts",
  "author": {
    "name": "Alice Evergreen",
    "email": "alice@teros.ai"
  },
  "availability": {
    "enabled": false,
    "multi": false,
    "system": false,
    "hidden": false,
    "role": "user"
  },
  "runtime": {
    "transport": "http",
    "containerMode": "per-app"
  },
  "keywords": [
    "todoist",
    "tasks",
    "todo",
    "productivity",
    "gtd"
  ],
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": false,
    "agent": false
  }
}