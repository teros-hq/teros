# Gmail MCA Environment Variables
# These are provided by the backend via callbackUrl

# System secrets (configured by admin)
# CLIENT_ID=your-google-oauth-client-id
# CLIENT_SECRET=your-google-oauth-client-secret
# REDIRECT_URIS=["https://your-backend-domain.com/auth/callback"]

# User secrets (obtained via OAuth flow)
# ACCESS_TOKEN=user-access-token
# REFRESH_TOKEN=user-refresh-token
# EMAIL=user@gmail.com
# EXPIRY_DATE=1234567890000
