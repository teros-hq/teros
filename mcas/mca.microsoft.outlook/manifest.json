{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.microsoft.outlook",
  "name": "Outlook",
  "version": "1.0.0",
  "description": "Microsoft Outlook email management - send, read, search, and organize emails via Microsoft Graph API",
  "type": "integration",
  "icon": "icon.png",
  "category": "productivity",
  "entrypoint": "src/index.ts",
  "author": {
    "name": "Teros Team",
    "email": "team@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": true,
    "system": false,
    "hidden": false,
    "role": "user"
  },
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": {
      "type": "oauth2",
      "provider": "microsoft",
      "systemSecrets": ["CLIENT_ID", "CLIENT_SECRET", "REDIRECT_URIS"],
      "userSecrets": ["ACCESS_TOKEN", "REFRESH_TOKEN", "EMAIL", "EXPIRY_DATE"],
      "authorizeUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "scopes": [
        "openid",
        "profile",
        "email",
        "offline_access",
        "Mail.Read",
        "Mail.ReadWrite",
        "Mail.Send",
        "User.Read"
      ],
      "pkce": false
    },
    "agent": false
  },
  "runtime": {
    "transport": "http",
    "port": 3000,
    "healthCheck": "/health",
    "containerMode": "per-app"
  },
  "keywords": ["outlook", "email", "microsoft", "mail", "messages", "office365", "hotmail"]
}
