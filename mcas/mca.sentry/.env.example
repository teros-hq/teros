# Sentry Auth Token
# Get it from: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: org:read, project:read, event:read, event:write
MCA_SECRET_APIKEY=sntryu_xxxxx...

# Optional: Self-hosted Sentry URL (default: https://sentry.io)
# SENTRY_BASE_URL=https://your-sentry-instance.com
