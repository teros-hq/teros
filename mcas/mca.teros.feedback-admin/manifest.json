{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.teros.feedback-admin",
  "name": "Feedback Admin",
  "version": "1.0.0",
  "description": "Manage user feedback: review bug reports and suggestions, update status, set priorities, and communicate updates to users.",
  "type": "system",
  "icon": "icon.png",
  "category": "system",
  "entrypoint": "src/index.ts",
  "author": {
    "name": "Teros Team",
    "email": "hello@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": false,
    "system": false,
    "hidden": false,
    "role": "admin"
  },
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": false,
    "agent": false
  },
  "runtime": {
    "transport": "http",
    "port": 3000,
    "healthCheck": "/health",
    "containerMode": "per-app"
  },
  "keywords": ["feedback", "admin", "bugs", "suggestions", "management"]
}
