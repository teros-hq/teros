{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.replicate",
  "name": "Replicate",
  "version": "1.0.0",
  "description": "Run AI models on Replicate - FLUX image generation, Minimax video, Veo video, and thousands of other models.",
  "type": "ai",
  "icon": "icon.png",
  "category": "ai",
  "entrypoint": "src/index.ts",
  "author": {
    "name": "Alice Evergreen",
    "email": "alice@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": false,
    "system": false,
    "hidden": false,
    "role": "user"
  },
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": {
      "type": "api-key",
      "systemSecrets": ["API_TOKEN"]
    },
    "agent": false
  },
  "runtime": {
    "transport": "http",
    "containerMode": "per-app",
    "port": 3000,
    "healthCheck": "/health"
  },
  "keywords": ["replicate", "ai", "ml", "flux", "image-generation", "video", "models"]
}
