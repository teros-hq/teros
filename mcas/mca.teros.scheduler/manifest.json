{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.teros.scheduler",
  "name": "Scheduler & Reminders",
  "version": "0.9.0",
  "description": "Schedule reminders and recurring tasks with natural language time expressions",
  "type": "utility",
  "icon": "icon.png",
  "category": "productivity",
  "entrypoint": "src/index.ts",
  "author": {
    "name": "Alice Evergreen",
    "email": "alice@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": false,
    "system": true,
    "hidden": true,
    "role": "user"
  },
  "runtime": {
    "transport": "http",
    "containerMode": "per-app"
  },
  "keywords": ["scheduler", "reminders", "recurring", "tasks", "cron", "time"],
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": false,
    "agent": false
  }
}
