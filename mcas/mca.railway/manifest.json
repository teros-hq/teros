{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.railway",
  "name": "Railway",
  "version": "1.0.0",
  "description": "Deploy projects to Railway directly from Teros workspaces. Supports automatic deployments, environment management, and database provisioning.",
  "type": "integration",
  "icon": "icon.png",
  "category": "development",
  "entrypoint": "src/index.ts",
  "author": {
    "name": "Alice Evergreen",
    "email": "alice@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": true,
    "system": false,
    "hidden": false,
    "role": "user"
  },
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": {
      "type": "api-key",
      "userSecrets": ["RAILWAY_TOKEN"]
    },
    "agent": false
  },
  "runtime": {
    "transport": "http",
    "containerMode": "per-app",
    "port": 3000,
    "healthCheck": "/health"
  },
  "keywords": ["railway", "deploy", "paas", "hosting", "docker", "deployment", "staging", "production"]
}
