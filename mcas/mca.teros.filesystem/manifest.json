{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.teros.filesystem",
  "name": "Filesystem",
  "version": "1.0.0",
  "description": "File system operations within a mounted volume. Read, write, edit, list, search files and content.",
  "type": "utility",
  "icon": "icon.png",
  "category": "development",
  "entrypoint": "src/index.ts",
  "author": {
    "name": "Alice Evergreen",
    "email": "alice@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": true,
    "system": false,
    "hidden": false,
    "role": "user"
  },
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": false,
    "agent": false
  },
  "runtime": {
    "transport": "http",
    "port": 3000,
    "healthCheck": "/health",
    "containerMode": "per-app"
  },
  "keywords": ["files", "filesystem", "read", "write", "edit", "search"]
}
