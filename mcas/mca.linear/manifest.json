{
  "$schema": "https://teros.ai/schemas/mca-manifest.json",
  "id": "mca.linear",
  "name": "Linear",
  "version": "1.0.0",
  "description": "Linear issue tracking - list, create, update issues, manage teams and users",
  "type": "integration",
  "icon": "icon.png",
  "category": "productivity",
  "entrypoint": "./src/index.ts",
  "author": {
    "name": "Teros Team",
    "email": "team@teros.ai"
  },
  "availability": {
    "enabled": true,
    "multi": false,
    "system": false,
    "hidden": false,
    "role": "user"
  },
  "userSecrets": ["API_KEY"],
  "runtime": {
    "transport": "http",
    "containerMode": "per-app",
    "port": 3000,
    "healthCheck": "/health"
  },
  "keywords": ["linear", "issues", "tasks", "project-management"],
  "layers": {
    "tools": true,
    "events": false,
    "ui": false,
    "permissions": false,
    "auth": false,
    "agent": false
  }
}
